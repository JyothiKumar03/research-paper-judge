# -----------------------------------------------------------------------
# Python
# -----------------------------------------------------------------------
# Bytecode cache — auto-generated, never commit (any depth)
**/__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/

# -----------------------------------------------------------------------
# Virtual environments
# -----------------------------------------------------------------------
.venv/
venv/
env/
.python-version

# -----------------------------------------------------------------------
# Environment variables — NEVER commit real secrets
# -----------------------------------------------------------------------
.env
!.env.example

# -----------------------------------------------------------------------
# Package managers
# -----------------------------------------------------------------------
uv.lock
.uv/

# -----------------------------------------------------------------------
# Databases & runtime data
# -----------------------------------------------------------------------
*.db
*.sqlite
*.sqlite3
backend/data/

# -----------------------------------------------------------------------
# Temporary / downloaded files
# -----------------------------------------------------------------------
*.tmp
*.pdf
/tmp/

# -----------------------------------------------------------------------
# Scripts folder — standalone utilities, not part of the app
# -----------------------------------------------------------------------
scripts/

# -----------------------------------------------------------------------
# Claude Code internal files
# -----------------------------------------------------------------------
.claude/

# -----------------------------------------------------------------------
# IDE
# -----------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo

# -----------------------------------------------------------------------
# OS
# -----------------------------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini

# -----------------------------------------------------------------------
# Streamlit
# -----------------------------------------------------------------------
.streamlit/secrets.toml

# -----------------------------------------------------------------------
# Testing
# -----------------------------------------------------------------------
.pytest_cache/
.coverage
htmlcov/
coverage.xml

# -----------------------------------------------------------------------
# Logs
# -----------------------------------------------------------------------
*.log
logs/
